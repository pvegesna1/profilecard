<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Influencer Profile Card</title>
  <link rel="stylesheet" href="style.css">
</head>
<body>

<div class="card">
  <img src="https://via.placeholder.com/120" class="profile-img" alt="Profile">

  <div class="info">
    <h2 id="name">Alex Influencer</h2>
    <p id="niche">Travel Blogger</p>
    <p>Sharing amazing travel experiences 🌍</p>

    <input type="text" id="nameInput" placeholder="Enter new name">
    <button id="updateBtn">Update Name</button>

    <button id="followBtn">Follow</button>
    <p id="followers">Followers: 1000</p>

    <button id="achievementBtn">Get Achievement</button>
    <p id="achievement"></p>
  </div>
</div>

<script src="script.js"></script>
</body>
</html>
